#include <format>
#include <stdexcept>
#include <random>
#include "SicBo.h"
#include <iostream>
using namespace std;


// get random integer
int SicBo::randomInteger() {
    static random_device rd;
    static default_random_engine engine{ rd() };
    static uniform_int_distribution randomInt{ 1, 6 };
    return randomInt(engine);
}


void SicBo::play() {

    double amount{ 0.0 };
    int diceNumber{ 0 }, winCount{ 0 };
    // to store the three dice number
    vector<int> threeDice{};

    // enter current balance, then bet amount
    cout << "Current balance: $" << player->getBalance() << "\n";
    cout << "\nEnter bet amount: ";
    cin >> amount;

    // withdraw bet first (player places the bet)
    player->withdraw(amount);

    // choose a dice number from 1-6
    cout << "Pick a number (1 - 6): ";
    cin >> diceNumber;

    // validate input
    while (diceNumber < 1 || diceNumber > 6) {
        cout << "Invalid input! Please enter a number between 1 and 6: ";
        cin >> diceNumber;
    }

    // loop three times and add 3 elements to the vector
    for (int i = 0; i < 3; i++) {
        int randomNum{ randomInteger() };
        threeDice.push_back(randomNum);
    }

    // display dices rolled
    cout << "Dices rolled: ";
    for (int i : threeDice) {
        cout << i << " ";
    }
    cout << "\n";

    // count matches
    for (int i : threeDice) {
        if (i == diceNumber) {
            ++winCount;
        }
    }

    // payout logic (add winnings back)
    if (winCount == 1) {
        player->deposit(amount * 2.0);
    }
    else if (winCount == 2) {
        player->deposit(amount * 3.0);
    }
    else if (winCount == 3) {
        player->deposit(amount * 5.0);
    }
    // no matches → player already lost bet, nothing else happens
}
